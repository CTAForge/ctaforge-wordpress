{
  "name": "ctaforge/ctaforge-wordpress",
  "description": "Official WordPress plugin for CTAForge email marketing platform",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "require": {
    "php": ">=8.0"
  },
  "require-dev": {
    "wp-coding-standards/wpcs": "^3.0",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "phpunit/phpunit": "^10.0",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "CTAForge\\": "includes/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "CTAForge\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=WordPress trunk/ --extensions=php",
    "test": "phpunit --configuration phpunit.xml"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}
